---
import { getCollection } from 'astro:content';
import { slugify } from '../utils/slugify';

const allPosts = await getCollection('posts');
const tagCounts = new Map<string, { name: string; slug: string; count: number }>();

for (const post of allPosts.filter(post => !post.data.hidden)) {
  for (const tag of post.data.tags) {
    const s = slugify(tag);
    const existing = tagCounts.get(s);
    if (existing) {
      existing.count++;
    } else {
      tagCounts.set(s, { name: tag, slug: s, count: 1 });
    }
  }
}

const sortedTags = Array.from(tagCounts.values()).sort((a, b) =>
  a.name.localeCompare(b.name, 'en', { sensitivity: 'base' })
);
---

<aside class="sidebar" aria-label="Sidebar" data-pagefind-ignore>

  <div class="site-identity">
    <a href="/" class="site-identity-link">
      <img
        class="site-avatar"
        src="/avatar.jpg"
        alt="Nathan Pitman"
        width="56"
        height="56"
      />
      <div class="site-identity-text">
        <span class="hello">hello, my name is</span>
        <span class="name">nathan pitman.</span>
      </div>
    </a>
  </div>

  <div class="sidebar-block">
    <div class="sidebar-block-header">
      <span class="sidebar-block-title">Tags</span>
    </div>
    <ul class="sidebar-list">
      {sortedTags.map(tag => (
        <li data-tag={tag.slug}>
          <a href={`/tag/${tag.slug}`}>{tag.name} ({tag.count})</a>
        </li>
      ))}
    </ul>
  </div>

  <div class="sidebar-block">

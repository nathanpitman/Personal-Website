---
const { title, activeNav } = Astro.props;
const year = new Date().getFullYear();
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;1,400&family=Source+Sans+3:wght@300;400;600&display=swap"
    rel="stylesheet"
  />
  <link rel="stylesheet" href="/styles/main.css" />
  <link rel="alternate" type="application/rss+xml" title="Nathan Pitman" href="/feed.xml" />
  <link rel="alternate" type="application/json" title="Nathan Pitman" href="/feed.json" />
</head>
<body>

  <nav class="site-nav" aria-label="Primary navigation">
    <ul>
      <li class={activeNav === 'recently'  ? 'active' : ''}><a href="/">recently</a></li>
      <li class={activeNav === 'archives'  ? 'active' : ''}><a href="/archives">archives</a></li>
      <li class={activeNav === 'about'     ? 'active' : ''}><a href="/about">about</a></li>
    </ul>
  </nav>

  <slot />

  <footer class="site-footer">
    <div class="site-footer-inner">
      &copy; 2003&ndash;{year} Nathan Pitman &mdash;
      Published with <a href="https://astro.build" target="_blank" rel="noopener">Astro</a> on GitHub Pages &mdash;
      <a href="https://bsky.app/profile/nathanpitman.bsky.social" target="_blank" rel="noopener">Follow me on Bluesky</a>
    </div>
  </footer>

</body>
</html>
